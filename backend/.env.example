# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

PORT=3000

# Generate a strong random string for this — e.g. run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Free key from: https://fdc.nal.usda.gov/api-guide.html (instant, no credit card)
USDA_API_KEY=your_usda_api_key_here

DB_HOST=localhost
DB_PORT=5432
DB_NAME=meal_plan_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Email verification (optional in dev — link prints to console if SMTP_HOST is missing)
# For Gmail: use an App Password (myaccount.google.com/apppasswords), SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
FRONTEND_URL=http://localhost:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=NutriPlan <your_email@gmail.com>
